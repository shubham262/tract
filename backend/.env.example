PORT=3001

# Supabase Postgres — pooled connection (PgBouncer, port 6543), used at runtime by PrismaClient's pg adapter
DATABASE_URL=

# Supabase Postgres — direct connection (port 5432), used by Prisma Migrate/introspection only
DIRECT_URL=

# Supabase Dashboard → Settings → API → JWT Settings → JWT Secret

SUPABASE_URL=
SUPABASE_ANON_KEY=
